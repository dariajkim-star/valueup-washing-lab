# ── 밸류업 워싱 스크리너 환경변수 예시 ──
# 복사해서 .env 로 쓰세요:  cp .env.example .env

# DB (PostgreSQL 기본 / 로컬 개발은 sqlite 폴백)
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/valueup
DATABASE_URL=sqlite:///./valueup.db

DEBUG=false

# 외부 소스 API 키 (소스 3종: DART · KRX · ECOS)
DART_API_KEY=
ECOS_API_KEY=
# KRX 시가총액·거래대금 조회에 로그인 필요 (data.krx.co.kr 무료 가입)
# ⚠️ 보안: 개인 KRX 계정을 장기 배치에 넣으면 로그인 반복으로 계정 잠금 위험.
#         CI/로그에 노출 금지. 운영은 Secret Manager 사용 권장.
KRX_ID=
KRX_PW=

# 워싱 판정 임계치
WASHING_PROGRESS_MIN=0.5
WASHING_ACHIEVEMENT_MAX=0.6

# Value-up 실행점수 가중치 (합 1.0)
SCORE_W_ACHIEVEMENT=0.5
SCORE_W_BUYBACK=0.3
SCORE_W_PAYOUT=0.2

# M&A Target Score 가중치 (합 1.0)
MNA_W_VALUATION=0.35
MNA_W_CAPACITY=0.25
MNA_W_OWNERSHIP=0.25
MNA_W_MACRO=0.15
